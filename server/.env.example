# Default in code is 5050 (macOS often uses 5000 for AirPlay — avoid EADDRINUSE).
PORT=5050
CLIENT_ORIGIN=http://localhost:5173

# MongoDB (Atlas or local). Required for Stage 1+.
# Replace USER:PASSWORD with your database user (no < > brackets — those were only placeholders in Atlas).
# Include a database name before ? e.g. ...mongodb.net/fitflow?retryWrites=true&w=majority
# Example: mongodb+srv://USER:PASSWORD@cluster.mongodb.net/fitflow?retryWrites=true&w=majority
MONGODB_URI=

# Required for Stage 2+ (JWT). Use a long random string in production.
JWT_SECRET=MiO7MqenoEfTEQAw4uxTSq99kmfbS0etXDgQo1H3C7w=

# Optional for nutrition-search hybrid mode (recommended).
# Get free key from USDA FoodData Central, server-side only.
USDA_API_KEY=
